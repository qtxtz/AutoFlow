<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginBottom="8dp">

    <!-- Green accent left bar -->
    <View
        android:layout_width="3dp"
        android:layout_height="match_parent"
        android:background="#7CB342"
        android:layout_marginEnd="6dp"/>

    <!-- Card content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/item_operation_compact_bg"
        android:padding="8dp">

        <!-- Row 1: reorder + bbox field + action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/btn_move_up"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:gravity="center"
                android:text="↑"
                android:textSize="12sp"
                android:textColor="#7CB342"
                android:background="@drawable/item_operation_compact_bg"/>

            <TextView
                android:id="@+id/btn_move_down"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:gravity="center"
                android:text="↓"
                android:textSize="12sp"
                android:textColor="#7CB342"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/item_operation_compact_bg"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="区域"
                android:textSize="11sp"
                android:textColor="#7CB342"
                android:textStyle="bold"
                android:layout_marginEnd="4dp"/>

            <EditText
                android:id="@+id/edt_match_bbox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="x,y,w,h"
                android:textSize="11sp"
                android:inputType="text"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/btn_pick_region"
                android:layout_width="30dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="框选"
                android:textSize="10sp"
                android:textColor="#315dbf"
                android:background="@drawable/item_operation_compact_bg"
                android:layout_marginEnd="3dp"/>

            <TextView
                android:id="@+id/btn_import_bbox"
                android:layout_width="30dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="导入"
                android:textSize="10sp"
                android:textColor="#7CB342"
                android:background="@drawable/item_operation_compact_bg"
                android:layout_marginEnd="3dp"/>

            <TextView
                android:id="@+id/btn_preview_region"
                android:layout_width="30dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="预览"
                android:textSize="10sp"
                android:textColor="#E08A1E"
                android:background="@drawable/item_operation_compact_bg"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/btn_delete_entry"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:gravity="center"
                android:text="✕"
                android:textSize="11sp"
                android:textColor="#B23B3B"
                android:background="@drawable/item_operation_compact_bg"/>
        </LinearLayout>

        <!-- Thin divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1A7CB342"
            android:layout_marginBottom="6dp"/>

        <!-- Row 2: templates + similarity -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="模板"
                android:textSize="11sp"
                android:textColor="#7CB342"
                android:textStyle="bold"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/tv_selected_templates"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="（点击「选」添加）"
                android:textSize="11sp"
                android:textColor="#2a3a4a"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/btn_select_templates"
                android:layout_width="30dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="选"
                android:textSize="11sp"
                android:textColor="#315dbf"
                android:textStyle="bold"
                android:background="@drawable/item_operation_compact_bg"
                android:layout_marginEnd="8dp"/>

            <View
                android:layout_width="1dp"
                android:layout_height="18dp"
                android:background="#DDE3EA"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="相似"
                android:textSize="11sp"
                android:textColor="#4e5f74"
                android:layout_marginEnd="4dp"/>

            <EditText
                android:id="@+id/edt_match_similarity"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:hint="0.88"
                android:textSize="11sp"
                android:inputType="numberDecimal"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
