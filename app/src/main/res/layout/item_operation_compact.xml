<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="6dp"
    android:layout_marginTop="2dp"
    android:layout_marginEnd="6dp"
    android:layout_marginBottom="2dp"
    android:background="@drawable/project_panel_operation_row_bg"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="7dp"
    android:paddingTop="5dp"
    android:paddingEnd="7dp"
    android:paddingBottom="5dp">

    <View
        android:id="@+id/selection_indicator"
        android:layout_width="3dp"
        android:layout_height="26dp"
        android:layout_marginEnd="7dp"
        android:background="#3C6DE4"
        android:visibility="invisible" />

    <TextView
        android:id="@+id/operation_index"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:background="@drawable/project_panel_operation_badge_bg"
        android:gravity="center"
        android:text="01"
        android:textColor="#FFFFFF"
        android:textSize="9sp"
        android:textStyle="bold" />

    <FrameLayout
        android:id="@+id/operation_visual"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginStart="6dp"
        android:background="@drawable/project_panel_icon_chip">

        <ImageView
            android:id="@+id/operation_visual_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="6dp"
            android:scaleType="centerInside" />

        <TextView
            android:id="@+id/operation_visual_text"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="var"
            android:textColor="#3167D8"
            android:textSize="8sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="7dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- 顶部行：延迟 chip + 编辑按钮 + 类型 chip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/node_pre_delay_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/project_panel_type_chip_bg"
                android:paddingStart="5dp"
                android:paddingEnd="5dp"
                android:paddingTop="1dp"
                android:paddingBottom="1dp"
                android:textSize="9sp"
                android:textColor="#8A97A6"
                android:textStyle="bold"
                android:text="等 0ms" />

            <ImageView
                android:id="@+id/btn_node_pre_delay"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="2dp"
                android:background="@drawable/project_panel_toolbar_icon_bg"
                android:padding="3dp"
                android:src="@drawable/ic_edit"
                android:tint="#A0AEBB" />

            <Space
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/operation_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/project_panel_type_chip_bg"
                android:paddingStart="5dp"
                android:paddingTop="1dp"
                android:paddingEnd="5dp"
                android:paddingBottom="1dp"
                android:textColor="#546273"
                android:textSize="9sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- 节点名称 -->
        <TextView
            android:id="@+id/list_item_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#243244"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- 节点 ID -->
        <TextView
            android:id="@+id/operation_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#9AAABB"
            android:textSize="9sp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/template_preview_strip"
        android:layout_width="112dp"
        android:layout_height="34dp"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="6dp"
        android:gravity="center_vertical|end"
        android:orientation="horizontal"
        android:visibility="gone" />

    <View
        android:id="@+id/float_btn_dot"
        android:layout_width="6dp"
        android:layout_height="6dp"
        android:layout_marginEnd="5dp"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/more_options"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:background="@drawable/project_panel_toolbar_icon_bg"
        android:padding="4dp"
        android:src="@drawable/ic_more_vert"
        android:tint="#728090" />

    <CheckBox
        android:id="@+id/chk_batch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="2dp"
        android:buttonTint="@color/colorPrimary"
        android:visibility="gone" />

</LinearLayout>
