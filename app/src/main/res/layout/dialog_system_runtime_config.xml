<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/dialog_background"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:id="@+id/dialog_drag_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="系统参数"
            android:textColor="#1F2937"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_system_config_close"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="×"
            android:textColor="#64748B"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/item_operation_compact_bg"
                android:padding="10dp"
                android:text="保存后立即影响新的轮询控制器和后续手势录制；采集倍率会重建/影响当前截图采集。"
                android:textColor="#526273"
                android:textSize="12sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="采集"
                android:textColor="#111827"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/et_system_capture_scale"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:hint="CAPTURE_SCALE"
                    android:inputType="numberDecimal"
                    android:singleLine="true"
                    android:textColor="#1F2937"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/et_system_idle_pause_ms"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:hint="Idle pause ms"
                    android:inputType="number"
                    android:singleLine="true"
                    android:textColor="#1F2937"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="手势录制"
                android:textColor="#111827"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_system_gesture_record_idle_finish_ms"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="6dp"
                android:hint="空闲结束等待(ms)"
                android:inputType="number"
                android:singleLine="true"
                android:textColor="#1F2937"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="模板匹配轮询 ms"
                android:textColor="#111827"
                android:textSize="15sp"
                android:textStyle="bold" />

            <include
                android:id="@+id/include_template_polling"
                layout="@layout/include_polling_triplet_system_config" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="图集匹配轮询 ms"
                android:textColor="#111827"
                android:textSize="15sp"
                android:textStyle="bold" />

            <include
                android:id="@+id/include_match_map_polling"
                layout="@layout/include_polling_triplet_system_config" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="颜色操作轮询 ms"
                android:textColor="#111827"
                android:textSize="15sp"
                android:textStyle="bold" />

            <include
                android:id="@+id/include_color_polling"
                layout="@layout/include_polling_triplet_system_config" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_system_config_reset"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="默认值"
            android:textColor="#64748B"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btn_system_config_cancel"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="取消"
            android:textColor="#64748B"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btn_system_config_save"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="保存"
            android:textColor="#0F766E"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
