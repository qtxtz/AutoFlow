<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/dialog_background"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="配置面板"
        android:textColor="#1F2937"
        android:textSize="18sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/et_builder_schema_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="面板标题"
        android:inputType="text|textNoSuggestions"
        android:singleLine="true"
        android:textColor="#243244"
        android:textSize="14sp" />

    <HorizontalScrollView
        android:id="@+id/scroll_builder_pages"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/layout_builder_pages"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_builder_add_page"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="新页面"
            android:textColor="#2F4F7C"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btn_builder_rename_page"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="改名"
            android:textColor="#2F4F7C"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btn_builder_delete_page"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="删页面"
            android:textColor="#C2410C"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_builder_page_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#6B7280"
        android:textSize="12sp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_builder_add_switch"
                android:layout_width="76dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/item_operation_compact_bg"
                android:gravity="center"
                android:text="勾选"
                android:textColor="#15803D"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/btn_builder_add_select"
                android:layout_width="76dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/item_operation_compact_bg"
                android:gravity="center"
                android:text="选择"
                android:textColor="#1D4ED8"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/btn_builder_add_multi_select"
                android:layout_width="76dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/item_operation_compact_bg"
                android:gravity="center"
                android:text="多选"
                android:textColor="#7C3AED"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/btn_builder_add_text"
                android:layout_width="76dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/item_operation_compact_bg"
                android:gravity="center"
                android:text="文本"
                android:textColor="#0F766E"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/btn_builder_add_number"
                android:layout_width="76dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/item_operation_compact_bg"
                android:gravity="center"
                android:text="数字"
                android:textColor="#C2410C"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/btn_builder_add_textarea"
                android:layout_width="76dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/item_operation_compact_bg"
                android:gravity="center"
                android:text="多行"
                android:textColor="#0F766E"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/btn_builder_add_title"
                android:layout_width="76dp"
                android:layout_height="36dp"
                android:background="@drawable/item_operation_compact_bg"
                android:gravity="center"
                android:text="分组"
                android:textColor="#111827"
                android:textSize="13sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:fillViewport="false">

        <LinearLayout
            android:id="@+id/layout_builder_components"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_builder_preview"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="预览"
            android:textColor="#2F4F7C"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btn_builder_cancel"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="取消"
            android:textColor="#6A7682"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btn_builder_save"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="保存"
            android:textColor="#0F766E"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
