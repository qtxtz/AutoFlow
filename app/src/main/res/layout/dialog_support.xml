<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="false"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/dialog_background"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/tv_support_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="支持作者"
            android:textColor="#213043"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_support_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:lineSpacingExtra="2dp"
            android:text="如果这个工具帮你节省了时间，可以自愿支持一下项目维护。保存收款码后可在支付宝中识别。"
            android:textColor="#667386"
            android:textSize="13sp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/home_main_surface_bg"
            android:padding="12dp">

            <ImageView
                android:id="@+id/iv_support_qr"
                android:layout_width="260dp"
                android:layout_height="260dp"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:background="#FFFFFF"
                android:contentDescription="支付宝收款码"
                android:padding="6dp"
                android:scaleType="fitCenter" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_support_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="图片仅保存在本机相册，不会上传任何信息。"
            android:textColor="#8A96A6"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_support_close"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/project_panel_btn_minor"
                android:gravity="center"
                android:text="稍后再说"
                android:textColor="#4B5A6C"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_support_save"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/project_panel_btn_primary"
                android:gravity="center"
                android:text="保存收款码"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
