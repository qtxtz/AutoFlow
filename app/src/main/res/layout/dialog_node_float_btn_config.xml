<?xml version="1.0" encoding="utf-8"?>
<!--
  悬浮按钮配置弹窗
  尺寸由 NodeFloatButtonUiHelper 按屏幕比例设置，内容过多时可滚动
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/project_panel_shell_bg"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── 标题 ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="悬浮按钮配置"
            android:textColor="#243244"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- ── 预览圆 ── -->
        <FrameLayout
            android:id="@+id/cfg_preview"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center_horizontal"
            android:elevation="3dp"
            android:layout_marginBottom="14dp">

            <ImageView
                android:id="@+id/cfg_preview_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:padding="6dp"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <TextView
                android:id="@+id/cfg_preview_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/cfg_preview_label"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="2"
                android:padding="5dp"
                android:textSize="10sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- ── 按钮文字 ── -->
        <TextView
            style="@style/CfgSectionLabel"
            android:text="按钮文字" />

        <EditText
            android:id="@+id/cfg_et_label"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:background="@drawable/item_operation_compact_bg"
            android:hint="不填则显示节点名称缩写"
            android:inputType="text"
            android:padding="8dp"
            android:singleLine="true"
            android:textColor="#243244"
            android:textColorHint="#AABBCC"
            android:textSize="12sp"
            android:layout_marginBottom="12dp" />

        <!-- ── 按钮颜色 ── -->
        <TextView
            style="@style/CfgSectionLabel"
            android:text="按钮颜色" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/cfg_color_swatches"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <!-- ── 外圈颜色 ── -->
        <TextView
            style="@style/CfgSectionLabel"
            android:text="外圈颜色" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:id="@+id/cfg_border_color_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="外圈粗细"
                android:textColor="#243244"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/cfg_border_minus"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="−"
                android:textColor="#3C6DE4"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/cfg_border_val"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="#243244"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/cfg_border_plus"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="+"
                android:textColor="#3C6DE4"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ── 文字颜色 ── -->
        <TextView
            style="@style/CfgSectionLabel"
            android:text="文字颜色" />

        <LinearLayout
            android:id="@+id/cfg_text_color_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp" />

        <!-- ── 自定义图片 ── -->
        <TextView
            style="@style/CfgSectionLabel"
            android:text="自定义图片" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <EditText
                android:id="@+id/cfg_et_image"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@drawable/item_operation_compact_bg"
                android:clickable="false"
                android:cursorVisible="false"
                android:focusable="false"
                android:hint="未选择图片"
                android:inputType="none"
                android:padding="8dp"
                android:singleLine="true"
                android:textColor="#243244"
                android:textColorHint="#AABBCC"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/cfg_btn_pick_image"
                android:layout_width="52dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/item_operation_compact_bg"
                android:gravity="center"
                android:text="选择"
                android:textColor="#3C6DE4"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/cfg_btn_clear_image"
                android:layout_width="52dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/item_operation_compact_bg"
                android:gravity="center"
                android:text="清除"
                android:textColor="#6a7682"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- ── 内置图标 ── -->
        <TextView
            style="@style/CfgSectionLabel"
            android:text="图标库" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/cfg_icon_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <!-- ── 形状 ── -->
        <TextView
            style="@style/CfgSectionLabel"
            android:text="按钮形状" />

        <LinearLayout
            android:id="@+id/cfg_shape_row"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp" />

        <!-- ── 点击动效 ── -->
        <TextView
            style="@style/CfgSectionLabel"
            android:text="点击动效" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/cfg_effect_row"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center_vertical"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <!-- ── 运行状态样式 ── -->
        <TextView
            style="@style/CfgSectionLabel"
            android:text="运行状态样式" />

        <LinearLayout
            android:id="@+id/cfg_status_style_row"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp" />

        <!-- ── 大小 ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="大小"
                android:textColor="#243244"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/cfg_size_minus"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="−"
                android:textColor="#3C6DE4"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/cfg_size_val"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="#243244"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/cfg_size_plus"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="+"
                android:textColor="#3C6DE4"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ── 透明度 ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="透明度"
                android:textColor="#243244"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/cfg_alpha_minus"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="−"
                android:textColor="#3C6DE4"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/cfg_alpha_val"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="#243244"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/cfg_alpha_plus"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="+"
                android:textColor="#3C6DE4"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ── 执行时隐藏 ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="执行时隐藏按钮"
                android:textColor="#243244"
                android:textSize="13sp" />

            <CheckBox
                android:id="@+id/cfg_chk_hide"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- ── 位置 ── -->
        <TextView
            style="@style/CfgSectionLabel"
            android:text="位置" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingEnd="4dp"
                android:text="X"
                android:textColor="#5A6978"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/cfg_et_x"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:background="@drawable/item_operation_compact_bg"
                android:gravity="center"
                android:hint="0"
                android:inputType="number"
                android:padding="6dp"
                android:textColor="#243244"
                android:textColorHint="#AABBCC"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="8dp"
                android:paddingEnd="4dp"
                android:text="Y"
                android:textColor="#5A6978"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/cfg_et_y"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:background="@drawable/item_operation_compact_bg"
                android:gravity="center"
                android:hint="0"
                android:inputType="number"
                android:padding="6dp"
                android:textColor="#243244"
                android:textColorHint="#AABBCC"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/cfg_btn_pick"
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:background="@drawable/item_operation_compact_bg"
            android:gravity="center"
            android:text="点击屏幕选点"
            android:textColor="#3C6DE4"
            android:textSize="12sp"
            android:layout_marginBottom="14dp" />

        <!-- ── 底部操作按钮 ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- 仅当已有配置时才显示删除按钮 -->
            <TextView
                android:id="@+id/cfg_btn_delete"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="删除"
                android:textColor="#F44336"
                android:textSize="13sp"
                android:background="@drawable/item_operation_compact_bg"
                android:layout_marginEnd="6dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/cfg_btn_cancel"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="取消"
                android:textColor="#6a7682"
                android:textSize="13sp"
                android:background="@drawable/item_operation_compact_bg"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/cfg_btn_confirm"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="确定"
                android:textColor="#2f4f7c"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/item_operation_compact_bg" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
