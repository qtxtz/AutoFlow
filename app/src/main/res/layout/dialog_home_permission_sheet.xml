<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/tv_permission_sheet_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="权限管理"
        android:textColor="#111827"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_permission_sheet_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="主界面只保留一个权限按钮，点开后再处理具体权限。"
        android:textColor="#6B7280"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/btn_permission_accessibility"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/project_panel_row_bg"
        android:padding="12dp"
        android:text="无障碍"
        android:textColor="#253244"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/btn_permission_projection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/project_panel_row_bg"
        android:padding="12dp"
        android:text="录屏授权"
        android:textColor="#253244"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/btn_permission_overlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/project_panel_row_bg"
        android:padding="12dp"
        android:text="悬浮窗"
        android:textColor="#253244"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/btn_permission_battery"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/project_panel_row_bg"
        android:padding="12dp"
        android:text="权限加固"
        android:textColor="#253244"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/btn_permission_write_settings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/project_panel_row_bg"
        android:padding="12dp"
        android:text="修改系统设置(亮度)"
        android:textColor="#253244"
        android:textSize="14sp"
        android:textStyle="bold" />
</LinearLayout>
